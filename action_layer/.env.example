ACTION_LAYER_HOST=127.0.0.1
ACTION_LAYER_PORT=8100
# Optional: system env files loaded by action_layer/run.sh (':' separated, loaded before local .env).
# ACTION_LAYER_SYSTEM_ENV_FILES=/etc/wherecode/action_layer.env:$HOME/.wherecode/action_layer.env
# Auto-load defaults from local Codex config/auth when ACTION_LAYER_* is not set.
ACTION_LAYER_USE_CODEX_CONFIG=true
# Optional override:
# ACTION_LAYER_CODEX_CONFIG_PATH=$HOME/.codex/config.toml
# ACTION_LAYER_CODEX_AUTH_PATH=$HOME/.codex/auth.json
ACTION_LAYER_REQUIRE_LLM=true
ACTION_LAYER_EXECUTION_MODE=llm
ACTION_LAYER_LLM_PROVIDER=openai-compatible
ACTION_LAYER_LLM_BASE_URL=https://api.openai.com
ACTION_LAYER_LLM_WIRE_API=chat_completions
ACTION_LAYER_LLM_API_KEY=
ACTION_LAYER_LLM_MODEL=
ACTION_LAYER_LLM_TIMEOUT_SECONDS=30
ACTION_LAYER_LLM_TEMPERATURE=0.2
ACTION_LAYER_LLM_MAX_TOKENS=800
ACTION_LAYER_LLM_USER_AGENT=wherecode-action-layer/0.1
ACTION_LAYER_LLM_MAX_RETRIES=2
ACTION_LAYER_LLM_RETRY_DELAY_SECONDS=0.6
# Keep it short to reduce token usage.
ACTION_LAYER_LLM_SYSTEM_PROMPT=Return strict JSON with status,summary,discussion(optional),metadata(optional).
ACTION_LAYER_LLM_ROUTE_DEFAULT=default
ACTION_LAYER_LLM_ROUTE_BY_ROLE_JSON=
ACTION_LAYER_LLM_ROUTE_BY_MODULE_PREFIX_JSON=
# Optional multi-target config JSON (overrides single-target vars above when set).
# Example:
# ACTION_LAYER_LLM_TARGETS_JSON={"openai":{"provider":"openai-compatible","base_url":"https://api.openai.com","wire_api":"chat_completions","api_key_env":"OPENAI_API_KEY","model":"gpt-4.1-mini"},"gateway":{"provider":"openai-compatible","base_url":"https://your-gateway.example.com","wire_api":"responses","api_key_env":"GATEWAY_API_KEY","model":"qwen-max"},"local":{"provider":"ollama","base_url":"http://127.0.0.1:11434","model":"qwen2.5:7b"}}
ACTION_LAYER_LLM_TARGETS_JSON=
# For local diagnostics only (not for production):
# ACTION_LAYER_REQUIRE_LLM=false
# ACTION_LAYER_EXECUTION_MODE=mock
