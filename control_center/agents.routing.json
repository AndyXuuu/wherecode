{
  "default_agent": "coding-agent",
  "rules": [
    {
      "id": "rule_test_keywords",
      "agent": "test-agent",
      "priority": 10,
      "enabled": true,
      "keywords": [
        "pytest",
        "unit test",
        "integration test",
        "run tests",
        "coverage",
        "test"
      ]
    },
    {
      "id": "rule_review_keywords",
      "agent": "review-agent",
      "priority": 20,
      "enabled": true,
      "keywords": [
        "review",
        "security",
        "audit",
        "risk"
      ]
    }
  ]
}
